<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
  <title>משה - AI תזונה וכושר</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    :root { --primary:#111827; --bg:#f8fafc; }
    * { box-sizing: border-box; }
    body { font-family:'Inter',sans-serif; background-color:var(--bg); padding-bottom:90px; }
    .view-section { display:none; animation:fadeIn .25s ease-in-out; }
    .view-section.active { display:block; }
    @keyframes fadeIn { from{opacity:0; transform:translateY(8px);} to{opacity:1; transform:translateY(0);} }
    .chat-box { height:calc(100vh - 390px); min-height:340px; overflow-y:auto; scroll-behavior:smooth; }
    .message { max-width:86%; padding:12px 15px; border-radius:18px; margin-bottom:8px; font-size:15px; line-height:1.55; white-space:pre-wrap; word-break:break-word; }
    .message.ai { background:white; align-self:flex-start; border-bottom-right-radius:5px; box-shadow:0 2px 8px rgba(15,23,42,.06); border:1px solid #eef2f7; }
    .message.user { background:var(--primary); color:white; align-self:flex-end; border-bottom-left-radius:5px; }
    .message.system { background:#fff7ed; color:#9a3412; border:1px solid #fed7aa; align-self:center; max-width:100%; font-size:13px; }
    .nav-item.active { color:#111827; }
    .typing { display:inline-flex; gap:4px; align-items:center; }
    .typing span { width:6px; height:6px; border-radius:9999px; background:#94a3b8; animation:bounce 1s infinite; }
    .typing span:nth-child(2){ animation-delay:.12s; } .typing span:nth-child(3){ animation-delay:.24s; }
    @keyframes bounce { 0%,80%,100%{ transform:translateY(0); opacity:.4; } 40%{ transform:translateY(-4px); opacity:1; } }
    button:active { transform:scale(.97); }
    .chip { border:1px solid #e2e8f0; background:#fff; color:#334155; padding:8px 10px; border-radius:999px; font-size:12px; font-weight:700; white-space:nowrap; }
    .task-card { transition: all .2s ease; }
    .task-card.done { background:#ecfdf5; border-color:#bbf7d0; }
    .task-card.done .task-title { text-decoration: line-through; color:#64748b; }
    .task-check { width:28px; height:28px; border-radius:999px; border:2px solid #cbd5e1; display:flex; align-items:center; justify-content:center; font-weight:900; }
    .task-card.done .task-check { background:#16a34a; border-color:#16a34a; color:white; }
  </style>
</head>
<body class="bg-slate-50">
  <header class="bg-white border-b border-slate-200 sticky top-0 z-50 px-4 py-3 flex justify-between items-center shadow-sm">
    <div class="flex items-center gap-3">
      <h1 class="text-xl font-extrabold tracking-tight">משה AI</h1>
      <div class="bg-orange-50 text-orange-600 px-3 py-1 rounded-full text-sm font-bold border border-orange-100">🔥 <span id="streakCount">1</span></div>
    </div>
    <div class="flex gap-2">
      <button onclick="switchView('settings')" class="bg-slate-100 text-slate-700 px-3 py-1.5 rounded-xl text-xs font-bold">הגדרות</button>
      <button onclick="resetDay()" class="bg-red-50 text-red-600 px-3 py-1.5 rounded-xl text-xs font-bold">איפוס</button>
    </div>
  </header>

  <main class="max-w-md mx-auto p-4">
    <section id="view-stats" class="view-section active">
      <div class="bg-white rounded-[28px] p-6 mb-4 shadow-sm border border-slate-100 text-center">
        <p class="text-slate-500 font-bold text-sm mb-1">ציון בריאות יומי</p>
        <div class="flex items-center justify-center gap-2"><h2 id="gradeLetter" class="text-5xl font-black text-green-600">A</h2><span id="gradeNumber" class="text-slate-400 font-bold">(100)</span></div>
      </div>
      <div class="grid grid-cols-2 gap-3">
        <div class="col-span-2 bg-blue-50 p-5 rounded-[24px] text-center border border-blue-100"><span class="text-blue-600 text-xs font-bold block mb-1">🔥 סך קלוריות</span><h3 id="caloriesVal" class="text-3xl font-black text-blue-900">0</h3></div>
        <div class="bg-rose-50 p-5 rounded-[24px] text-center border border-rose-100"><span class="text-rose-600 text-xs font-bold block mb-1">🥩 חלבון</span><h3 id="proteinVal" class="text-2xl font-black text-rose-900">0g</h3></div>
        <div class="bg-amber-50 p-5 rounded-[24px] text-center border border-amber-100"><span class="text-amber-600 text-xs font-bold block mb-1">🍞 פחמימות</span><h3 id="carbsVal" class="text-2xl font-black text-amber-900">0g</h3></div>
        <div class="col-span-2 bg-emerald-50 p-5 rounded-[24px] text-center border border-emerald-100"><span class="text-emerald-600 text-xs font-bold block mb-1">🥑 שומנים</span><h3 id="fatsVal" class="text-2xl font-black text-emerald-900">0g</h3></div>
      </div>
      <div class="mt-4 bg-white rounded-[24px] p-4 border border-slate-100 shadow-sm">
        <h3 class="font-black text-slate-800 mb-2">סיכום מהיר</h3>
        <p id="dailyAdvice" class="text-sm text-slate-600 leading-6">התחילי לתעד ארוחות כדי לקבל המלצות.</p>
      </div>
      <div class="mt-4 bg-white rounded-[24px] p-4 border border-slate-100 shadow-sm flex items-center justify-between">
        <div>
          <h3 class="font-black text-slate-800">משימות היום</h3>
          <p id="tasksMiniSummary" class="text-sm text-slate-500 mt-1">0/0 הושלמו</p>
        </div>
        <button onclick="switchView('tasks')" class="bg-black text-white px-4 py-2 rounded-xl text-sm font-bold">פתחי</button>
      </div>
    </section>

    <section id="view-chat" class="view-section">
      <div class="flex gap-2 mb-3">
        <button onclick="document.getElementById('imageInput').click()" class="flex-1 bg-black text-white py-4 rounded-2xl font-bold flex items-center justify-center gap-2 shadow-lg transition-transform"><span>📸</span><span>צילום אוכל</span></button>
        <button onclick="clearChat()" class="bg-white text-slate-700 border border-slate-200 px-4 rounded-2xl font-bold">נקה</button>
        <input type="file" id="imageInput" class="hidden" accept="image/*" onchange="handleImageUpload(event)" />
      </div>
      <div class="bg-white border border-slate-200 rounded-[24px] p-4 flex flex-col shadow-sm">
        <div class="chat-box flex flex-col gap-2 overflow-y-auto mb-3 p-2" id="chatBox"></div>
        <div class="flex gap-2 overflow-x-auto pb-2 mb-2" id="quickChips">
          <button class="chip" onclick="fillAndSend('אכלתי 2 ביצים וטונה, כמה חלבון זה?')">חישוב חלבון</button>
          <button class="chip" onclick="fillAndSend('כמה אורז מבושל מתאים לי עכשיו?')">כמה פחמימה?</button>
          <button class="chip" onclick="fillAndSend('תציע לי ארוחת ערב עשירה בחלבון')">רעיון לארוחה</button>
        </div>
        <div class="flex gap-2 bg-slate-100 p-2 rounded-2xl">
          <input type="text" id="textInput" placeholder="כתבי למשה..." class="flex-1 bg-transparent border-none outline-none px-2 py-1 text-sm" autocomplete="off" />
          <button id="sendBtn" onclick="sendTextMessage()" class="bg-black text-white w-11 h-10 rounded-xl flex items-center justify-center font-bold">↑</button>
        </div>
      </div>
    </section>

    <section id="view-tasks" class="view-section">
      <div class="bg-white rounded-[24px] p-5 shadow-sm border border-slate-100 mb-4">
        <div class="flex items-start justify-between gap-3 mb-4">
          <div>
            <h2 class="text-lg font-black">✅ משימות יומיות</h2>
            <p class="text-sm text-slate-500 leading-6">סמני מה בוצע היום. המשימות מתאפסות אוטומטית בכל יום.</p>
          </div>
          <div class="bg-emerald-50 text-emerald-700 px-3 py-2 rounded-2xl text-center border border-emerald-100 min-w-[78px]">
            <div id="taskScore" class="text-2xl font-black">0%</div>
            <div class="text-[10px] font-bold">השלמה</div>
          </div>
        </div>

        <div id="tasksList" class="space-y-2"></div>
      </div>

      <div class="bg-white rounded-[24px] p-5 shadow-sm border border-slate-100">
        <h3 class="font-black mb-3">➕ הוספת משימה אישית</h3>
        <div class="flex gap-2 mb-3">
          <input id="newTaskInput" type="text" placeholder="לדוגמה: 10 דקות הליכה" class="flex-1 bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 outline-none focus:border-black">
          <button onclick="addCustomTask()" class="bg-black text-white px-5 py-3 rounded-xl font-bold">הוסף</button>
        </div>
        <div class="grid grid-cols-3 gap-2">
          <button onclick="addSuggestedTask('לשתות 2 ליטר מים','💧')" class="chip text-center">מים</button>
          <button onclick="addSuggestedTask('לאכול חלבון בכל ארוחה','🥩')" class="chip text-center">חלבון</button>
          <button onclick="addSuggestedTask('לסגור 8,000 צעדים','🚶')" class="chip text-center">צעדים</button>
        </div>
      </div>
    </section>

    <section id="view-progress" class="view-section">
      <div class="bg-white rounded-[24px] p-6 shadow-sm border border-slate-100">
        <h2 class="text-lg font-bold mb-4">⚖️ מעקב משקל</h2>
        <div class="flex gap-2 mb-6"><input type="number" step="0.1" id="weightInput" placeholder="0.0" class="flex-1 bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 outline-none focus:border-black"><button onclick="logWeight()" class="bg-black text-white px-6 py-3 rounded-xl font-bold">תיעוד</button></div>
        <div id="weightHistory" class="space-y-2"></div>
      </div>
    </section>

    <section id="view-settings" class="view-section">
      <div class="bg-white rounded-[24px] p-6 shadow-sm border border-slate-100">
        <h2 class="text-lg font-black mb-2">⚙️ הגדרות צ׳אט</h2>
        <p class="text-sm text-slate-500 leading-6 mb-4">בגרסה הזו לא מכניסים API key בתוך האפליקציה. המפתח נשמר בשרת של Vercel כ־Environment Variable בשם <b>GEMINI_API_KEY</b>, ולכן אפשר לפתוח את האפליקציה מכל מכשיר בלי להזין מפתח מחדש.</p>
        <button onclick="checkServerStatus()" class="bg-black text-white px-5 py-3 rounded-xl font-bold w-full">בדיקת חיבור לשרת</button>
        <div id="apiStatus" class="mt-4 text-sm font-bold"></div>
      </div>
    </section>
  </main>

  <nav class="fixed bottom-0 left-0 w-full bg-white border-t border-slate-200 flex justify-around items-center py-3 px-2 shadow-[0_-4px_20px_rgba(0,0,0,0.03)] z-50">
    <button onclick="switchView('stats')" id="nav-stats" class="nav-item active flex flex-col items-center gap-1 text-black"><span class="text-2xl">📊</span><span class="text-[10px] font-bold">נתונים</span></button>
    <button onclick="switchView('chat')" id="nav-chat" class="nav-item flex flex-col items-center gap-1 text-slate-400"><span class="text-2xl">💬</span><span class="text-[10px] font-bold">צ׳אט</span></button>
    <button onclick="switchView('tasks')" id="nav-tasks" class="nav-item flex flex-col items-center gap-1 text-slate-400"><span class="text-2xl">✅</span><span class="text-[10px] font-bold">משימות</span></button>
    <button onclick="switchView('progress')" id="nav-progress" class="nav-item flex flex-col items-center gap-1 text-slate-400"><span class="text-2xl">⚖️</span><span class="text-[10px] font-bold">משקל</span></button>
    <button onclick="switchView('settings')" id="nav-settings" class="nav-item flex flex-col items-center gap-1 text-slate-400"><span class="text-2xl">⚙️</span><span class="text-[10px] font-bold">הגדרות</span></button>
  </nav>

  <script>
    let appData = safeJson(localStorage.getItem('moshe_data'), {});
    let weightHistory = safeJson(localStorage.getItem('moshe_weight'), []);
    let chatHistory = safeJson(localStorage.getItem('moshe_chat_history'), []);
    let tasksData = safeJson(localStorage.getItem('moshe_tasks_data'), {});
    let customTasks = safeJson(localStorage.getItem('moshe_custom_tasks'), []);

    const defaultTasks = [
      { id:'water', icon:'💧', title:'לשתות לפחות 2 ליטר מים', points:10 },
      { id:'protein', icon:'🥩', title:'להגיע ליעד חלבון יומי', points:20 },
      { id:'vegetables', icon:'🥗', title:'להוסיף ירקות לפחות בארוחה אחת', points:10 },
      { id:'workout', icon:'🏋️', title:'אימון או הליכה של 20 דקות', points:20 },
      { id:'log_food', icon:'✍️', title:'לתעד לפחות ארוחה אחת בצ׳אט', points:10 },
      { id:'sleep', icon:'😴', title:'לתכנן שינה טובה הלילה', points:10 }
    ];

    const getToday = () => new Date().toISOString().split('T')[0];
    const emptyStats = () => ({ calories:0, protein:0, carbs:0, fats:0 });

    function safeJson(value, fallback) { try { return value ? JSON.parse(value) : fallback; } catch { return fallback; } }
    function switchView(viewName) {
      document.querySelectorAll('.view-section').forEach(v => v.classList.remove('active'));
      document.querySelectorAll('.nav-item').forEach(n => { n.classList.remove('active','text-black'); n.classList.add('text-slate-400'); });
      document.getElementById('view-' + viewName)?.classList.add('active');
      const activeNav = document.getElementById('nav-' + viewName);
      if (activeNav) { activeNav.classList.add('active','text-black'); activeNav.classList.remove('text-slate-400'); }
      if (viewName === 'chat') setTimeout(scrollChatToBottom, 50);
    }

    function updateUI() {
      const today = getToday();
      const stats = appData[today]?.stats || emptyStats();
      document.getElementById('caloriesVal').innerText = Math.round(stats.calories);
      document.getElementById('proteinVal').innerText = Math.round(stats.protein) + 'g';
      document.getElementById('carbsVal').innerText = Math.round(stats.carbs) + 'g';
      document.getElementById('fatsVal').innerText = Math.round(stats.fats) + 'g';

      const caloriePenalty = stats.calories > 2300 ? (stats.calories - 2300) / 18 : 0;
      const proteinBonus = Math.min(10, stats.protein / 12);
      const score = Math.max(0, Math.min(100, 88 + proteinBonus - caloriePenalty));
      document.getElementById('gradeNumber').innerText = `(${Math.round(score)})`;
      document.getElementById('gradeLetter').innerText = score > 90 ? 'A' : score > 75 ? 'B' : 'C';
      document.getElementById('dailyAdvice').innerText = makeDailyAdvice(stats);
      renderWeightHistory();
      renderTasks();
      renderChat();
      updateApiStatus();
    }

    function makeDailyAdvice(stats) {
      if (!stats.calories) return 'התחילי לתעד ארוחות כדי לקבל המלצות.';
      if (stats.protein < 80) return 'החלבון עדיין יחסית נמוך. נסי להוסיף מקור חלבון רזה בארוחה הבאה.';
      if (stats.calories > 2300) return 'הקלוריות כבר גבוהות יחסית. בארוחה הבאה עדיף חלבון רזה וירקות.';
      return 'יום מאוזן בינתיים. המשיכי לתעד כדי לקבל תמונה מדויקת.';
    }

    async function callGemini(userText, base64Image = null) {
      const todayStats = appData[getToday()]?.stats || emptyStats();

      const response = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type':'application/json' },
        body: JSON.stringify({ message:userText, image:base64Image, todayStats })
      });

      let data;
      try { data = await response.json(); }
      catch { data = { error:'השרת החזיר תשובה לא תקינה.' }; }

      if (!response.ok || data.error) throw new Error(data.error || 'שגיאת שרת לא ידועה');
      return normalizeAiResult(data);
    }

    function parseAiJson(raw) {
      try { return normalizeAiResult(JSON.parse(raw)); }
      catch {
        const match = raw.match(/\{[\s\S]*\}/);
        if (match) return normalizeAiResult(JSON.parse(match[0]));
        return { msg: raw || 'לא הצלחתי להבין את התשובה.', calories:0, protein:0, carbs:0, fats:0, isFood:false };
      }
    }

    function normalizeAiResult(res) {
      return {
        msg: String(res.msg || 'בוצע.'),
        calories: Number(res.calories || 0),
        protein: Number(res.protein || 0),
        carbs: Number(res.carbs || 0),
        fats: Number(res.fats || 0),
        isFood: Boolean(res.isFood || Number(res.calories || 0) > 0)
      };
    }

    function offlineCoach(text) {
      const lower = text.toLowerCase();
      const hasFoodWords = /עוף|ביצה|ביצים|טונה|אורז|לחם|קוסקוס|בורגול|תפוח|אדמה|סלט|גבינה|יוגורט|סקיר|חלבון|פסטה|בשר|דג/.test(lower);
      if (!hasFoodWords) {
        return { msg:'אני עובד כרגע במצב בסיסי כי לא הוגדר Gemini API key. הכניסי מפתח בהגדרות כדי לקבל צ׳אט AI מלא. בינתיים אפשר לכתוב ארוחות בסיסיות ואני אנסה להעריך בערך.', calories:0, protein:0, carbs:0, fats:0, isFood:false };
      }
      let calories = 0, protein = 0, carbs = 0, fats = 0;
      if (/ביצה|ביצים/.test(lower)) { calories += 75; protein += 6; fats += 5; }
      if (/טונה/.test(lower)) { calories += 120; protein += 25; fats += 1; }
      if (/עוף|חזה/.test(lower)) { calories += 250; protein += 45; fats += 5; }
      if (/אורז|קוסקוס|בורגול|פסטה|תפוח אדמה|לחם/.test(lower)) { calories += 180; carbs += 38; protein += 5; }
      if (/גבינה|יוגורט|סקיר/.test(lower)) { calories += 120; protein += 18; carbs += 8; }
      return { msg:`הערכה בסיסית ללא AI מלא: כ-${calories} קלוריות, ${Math.round(protein)}g חלבון, ${Math.round(carbs)}g פחמימות, ${Math.round(fats)}g שומן. לתשובה מדויקת יותר הכניסי API key בהגדרות.`, calories, protein, carbs, fats, isFood:true };
    }

    async function sendTextMessage() {
      const input = document.getElementById('textInput');
      const text = input.value.trim();
      if (!text) return;
      input.value = '';
      pushMessage(text, 'user');
      const typingId = addTyping();
      setSending(true);
      try {
        const res = await callGemini(text);
        removeMessage(typingId);
        handleAiResponse(res);
      } catch (err) {
        removeMessage(typingId);
        pushMessage('לא הצלחתי להתחבר ל-AI. בדקי שה-API key נכון ושיש אינטרנט.\n\nשגיאה: ' + err.message, 'system');
      } finally { setSending(false); }
    }

    function handleAiResponse(res) {
      pushMessage(res.msg, 'ai');
      if (res.isFood && res.calories > 0) addNutrition(res);
    }

    function addNutrition(res) {
      const today = getToday();
      if (!appData[today]) appData[today] = { stats: emptyStats() };
      ['calories','protein','carbs','fats'].forEach(key => appData[today].stats[key] += Number(res[key] || 0));
      localStorage.setItem('moshe_data', JSON.stringify(appData));
      markTaskDone('log_food');
      if (appData[today].stats.protein >= 100) markTaskDone('protein');
      updateUI();
    }

    function pushMessage(text, side) {
      chatHistory.push({ id: crypto.randomUUID ? crypto.randomUUID() : String(Date.now()+Math.random()), text, side, time: new Date().toISOString() });
      chatHistory = chatHistory.slice(-80);
      localStorage.setItem('moshe_chat_history', JSON.stringify(chatHistory));
      renderChat();
      scrollChatToBottom();
    }

    function addTyping() {
      const id = 'typing-' + Date.now();
      chatHistory.push({ id, text:'<typing>', side:'ai', time:new Date().toISOString() });
      renderChat();
      scrollChatToBottom();
      return id;
    }

    function removeMessage(id) {
      chatHistory = chatHistory.filter(m => m.id !== id);
      localStorage.setItem('moshe_chat_history', JSON.stringify(chatHistory));
      renderChat();
    }

    function renderChat() {
      const box = document.getElementById('chatBox');
      if (!box) return;
      if (!chatHistory.length) {
        chatHistory = [{ id:'welcome', side:'ai', text:'היי! אני משה. כתבי מה אכלת, שאלי על חלבון/פחמימות, או שלחי תמונת אוכל.', time:new Date().toISOString() }];
        localStorage.setItem('moshe_chat_history', JSON.stringify(chatHistory));
      }
      box.innerHTML = chatHistory.map(m => {
        const content = m.text === '<typing>' ? '<span class="typing"><span></span><span></span><span></span></span>' : escapeHtml(m.text);
        return `<div class="message ${m.side}">${content}</div>`;
      }).join('');
    }

    function escapeHtml(text) { const div = document.createElement('div'); div.textContent = text; return div.innerHTML; }
    function scrollChatToBottom() { const box = document.getElementById('chatBox'); if (box) box.scrollTop = box.scrollHeight; }
    function setSending(isSending) { document.getElementById('sendBtn').disabled = isSending; document.getElementById('sendBtn').style.opacity = isSending ? '.55' : '1'; }
    function fillAndSend(text) { document.getElementById('textInput').value = text; sendTextMessage(); }

    function handleImageUpload(event) {
      const file = event.target.files[0];
      if (!file) return;
      if (!file.type.startsWith('image/')) { pushMessage('אפשר להעלות רק תמונה.', 'system'); return; }
      const reader = new FileReader();
      reader.onload = async (e) => {
        const base64 = e.target.result.split(',')[1];
        pushMessage('שלחתי תמונת אוכל לניתוח 📸', 'user');
        const typingId = addTyping();
        setSending(true);
        try {
          const res = await callGemini('נתח את האוכל שבתמונה והערך קלוריות ומאקרו.', base64);
          removeMessage(typingId);
          handleAiResponse(res);
        } catch (err) {
          removeMessage(typingId);
          pushMessage('לא הצלחתי לנתח את התמונה. בדקי API key וחיבור לאינטרנט.\n\nשגיאה: ' + err.message, 'system');
        } finally { setSending(false); event.target.value = ''; }
      };
      reader.readAsDataURL(file);
    }

    function clearChat() {
      if (!confirm('לנקות את היסטוריית הצ׳אט?')) return;
      chatHistory = [];
      localStorage.removeItem('moshe_chat_history');
      renderChat();
    }

    function logWeight() {
      const val = document.getElementById('weightInput').value;
      if (!val) return;
      weightHistory.unshift({ date:new Date().toLocaleDateString('he-IL'), weight:val });
      localStorage.setItem('moshe_weight', JSON.stringify(weightHistory));
      document.getElementById('weightInput').value = '';
      renderWeightHistory();
    }

    function renderWeightHistory() {
      const container = document.getElementById('weightHistory');
      container.innerHTML = weightHistory.map(h => `<div class="flex justify-between items-center bg-slate-50 p-3 rounded-xl border border-slate-100"><span class="font-bold text-slate-700">${escapeHtml(h.weight)} ק״ג</span><span class="text-xs text-slate-400">${escapeHtml(h.date)}</span></div>`).join('') || '<p class="text-sm text-slate-400">עדיין אין תיעודי משקל.</p>';
    }

    function resetDay() {
      if (confirm('האם לאפס את נתוני היום?')) {
        appData[getToday()] = { stats: emptyStats() };
        tasksData[getToday()] = {};
        localStorage.setItem('moshe_data', JSON.stringify(appData));
        localStorage.setItem('moshe_tasks_data', JSON.stringify(tasksData));
        updateUI();
      }
    }

    async function checkServerStatus() {
      const status = document.getElementById('apiStatus');
      if (!status) return;
      status.className = 'mt-4 text-sm font-bold text-slate-500';
      status.innerText = 'בודק חיבור...';
      try {
        const response = await fetch('/api/health');
        const data = await response.json();
        if (response.ok && data.ok) {
          status.className = 'mt-4 text-sm font-bold text-emerald-600';
          status.innerText = '✅ השרת מחובר וה־Gemini API key מוגדר.';
        } else {
          status.className = 'mt-4 text-sm font-bold text-orange-600';
          status.innerText = '⚠️ השרת עובד, אבל חסר GEMINI_API_KEY בהגדרות Vercel.';
        }
      } catch (err) {
        status.className = 'mt-4 text-sm font-bold text-red-600';
        status.innerText = '❌ לא הצלחתי להתחבר לשרת. אם פתחת את הקובץ מהמחשב ולא דרך Vercel, הצ׳אט החכם לא יעבוד.';
      }
    }

    function updateApiStatus(customMsg, isWarn) {
      const status = document.getElementById('apiStatus');
      if (!status) return;
      status.className = 'mt-4 text-sm font-bold text-slate-500';
      status.innerText = customMsg || 'ℹ️ המפתח נשמר בשרת, לא בדפדפן. לחצי על בדיקת חיבור כדי לוודא שהכול מוגדר.';
    }

    function getAllTasks() {
      return [...defaultTasks, ...customTasks];
    }

    function todayTaskState() {
      const today = getToday();
      if (!tasksData[today]) tasksData[today] = {};
      return tasksData[today];
    }

    function renderTasks() {
      const list = document.getElementById('tasksList');
      const scoreEl = document.getElementById('taskScore');
      const mini = document.getElementById('tasksMiniSummary');
      if (!list) return;
      const state = todayTaskState();
      const tasks = getAllTasks();
      const doneCount = tasks.filter(t => state[t.id]).length;
      const percent = tasks.length ? Math.round((doneCount / tasks.length) * 100) : 0;

      if (scoreEl) scoreEl.innerText = percent + '%';
      if (mini) mini.innerText = `${doneCount}/${tasks.length} הושלמו`;
      document.getElementById('streakCount').innerText = calculateStreak();

      list.innerHTML = tasks.map(task => {
        const done = !!state[task.id];
        const canDelete = task.id.startsWith('custom-');
        return `
          <div class="task-card ${done ? 'done' : ''} flex items-center gap-3 border border-slate-200 rounded-2xl p-3">
            <button onclick="toggleTask('${task.id}')" class="task-check shrink-0">${done ? '✓' : ''}</button>
            <div class="flex-1">
              <div class="task-title font-bold text-slate-800">${escapeHtml(task.icon)} ${escapeHtml(task.title)}</div>
              <div class="text-xs text-slate-400 font-bold mt-1">${task.points || 10} נק׳</div>
            </div>
            ${canDelete ? `<button onclick="deleteCustomTask('${task.id}')" class="text-red-500 bg-red-50 px-3 py-2 rounded-xl text-xs font-bold">מחק</button>` : ''}
          </div>`;
      }).join('');
      localStorage.setItem('moshe_tasks_data', JSON.stringify(tasksData));
    }

    function toggleTask(taskId) {
      const state = todayTaskState();
      state[taskId] = !state[taskId];
      localStorage.setItem('moshe_tasks_data', JSON.stringify(tasksData));
      renderTasks();
    }

    function markTaskDone(taskId) {
      const state = todayTaskState();
      state[taskId] = true;
      localStorage.setItem('moshe_tasks_data', JSON.stringify(tasksData));
    }

    function addCustomTask() {
      const input = document.getElementById('newTaskInput');
      const title = input.value.trim();
      if (!title) return;
      customTasks.push({ id:'custom-' + Date.now(), icon:'⭐', title, points:10 });
      localStorage.setItem('moshe_custom_tasks', JSON.stringify(customTasks));
      input.value = '';
      renderTasks();
    }

    function addSuggestedTask(title, icon) {
      customTasks.push({ id:'custom-' + Date.now() + Math.random().toString(16).slice(2), icon, title, points:10 });
      localStorage.setItem('moshe_custom_tasks', JSON.stringify(customTasks));
      renderTasks();
    }

    function deleteCustomTask(taskId) {
      customTasks = customTasks.filter(t => t.id !== taskId);
      Object.keys(tasksData).forEach(date => delete tasksData[date][taskId]);
      localStorage.setItem('moshe_custom_tasks', JSON.stringify(customTasks));
      localStorage.setItem('moshe_tasks_data', JSON.stringify(tasksData));
      renderTasks();
    }

    function calculateStreak() {
      const tasks = getAllTasks();
      if (!tasks.length) return 1;
      let streak = 0;
      const d = new Date();
      for (let i = 0; i < 365; i++) {
        const day = new Date(d);
        day.setDate(d.getDate() - i);
        const key = day.toISOString().split('T')[0];
        const state = tasksData[key] || {};
        const completed = tasks.filter(t => state[t.id]).length;
        if (completed > 0) streak++;
        else if (i === 0) continue;
        else break;
      }
      return Math.max(1, streak);
    }

    document.getElementById('textInput').addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && !event.shiftKey) { event.preventDefault(); sendTextMessage(); }
    });
    document.getElementById('newTaskInput').addEventListener('keydown', (event) => {
      if (event.key === 'Enter') { event.preventDefault(); addCustomTask(); }
    });

    window.onload = updateUI;
  </script>
</body>
</html>
